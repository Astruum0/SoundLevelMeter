{
  "name": "sound-level-meter",
  "version": "0.1.0",
  "description": "A lightweight Electron sound level meter for microphone monitoring.",
  "main": "./out/main/index.js",
  "private": true,
  "packageManager": "npm@11.6.0",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:win": "npm run build && electron-builder --win nsis zip",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.codex.soundlevelmeter",
    "productName": "Sound Level Meter",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/appIcon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Sound Level Meter needs microphone access to show the live input level for your selected audio source."
      }
    },
    "win": {
      "icon": "assets/appIcon.ico",
      "target": [
        "zip"
      ]
    }
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^25.6.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "preact": "^10.29.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
